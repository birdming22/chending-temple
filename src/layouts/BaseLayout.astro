---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = '宸定精舍 - 如宸法師弘法道場' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | 宸定精舍</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;500;700&family=Noto+Sans+TC:wght@300;400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">
        <span class="logo-ch">宸定精舍</span>
        <span class="logo-sub">如宸法師弘法道場</span>
      </a>
      <nav class="main-nav">
        <a href="/">首頁</a>
        <a href="/about">關於法師</a>
        <a href="/activities">弘法活動</a>
        <a href="/temple">道場介紹</a>
        <a href="/contact">聯絡我們</a>
      </nav>
      <button class="nav-toggle" aria-label="開啟選單">&#9776;</button>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p class="footer-quote">「慈悲為懷，普度眾生」</p>
      <p class="footer-info">宸定精舍 &nbsp;|&nbsp; 彰化縣田尾鄉 &nbsp;|&nbsp; 如宸法師</p>
      <p class="footer-copy">&copy; {new Date().getFullYear()} 宸定精舍 版權所有</p>
    </div>
  </footer>

  <script>
    const toggle = document.querySelector('.nav-toggle');
    const nav = document.querySelector('.main-nav');
    toggle?.addEventListener('click', () => nav?.classList.toggle('open'));
  </script>
</body>
</html>

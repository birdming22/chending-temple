---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="聯絡我們" description="聯絡宸定精舍 — 彰化縣田尾鄉，如宸法師弘法道場，歡迎十方信眾蒞臨。">

  <section class="page-banner">
    <div class="container">
      <h1>聯絡我們</h1>
      <p>歡迎與道場聯繫，廣結善緣</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">聯絡方式</span>
        <h2>與宸定精舍聯繫</h2>
        <div class="divider"></div>
      </div>
      <div class="contact-grid">
        <div class="contact-card">
          <div class="icon">📍</div>
          <h3>道場地址</h3>
          <p>彰化縣田尾鄉 · 宸定精舍</p>
        </div>
        <div class="contact-card">
          <div class="icon">📘</div>
          <h3>Facebook</h3>
          <p>
            歡迎透過 Facebook<br/>
            關注如宸法師最新動態<br/>
            <a href="https://www.facebook.com/pages/%E5%AE%B8%E5%AE%9A%E7%B2%BE%E8%88%8D/1066930520019595" target="_blank" rel="noopener">
              前往 Facebook 專頁
            </a>
          </p>
        </div>
        <div class="contact-card">
          <div class="icon">🕐</div>
          <h3>參訪時間</h3>
          <p>請事先聯繫道場<br/>確認開放時間<br/>與共修活動安排</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <span class="section-label">注意事項</span>
        <h2>參訪須知</h2>
        <div class="divider"></div>
      </div>
      <div class="prose">
        <h3>事先聯繫</h3>
        <p>
          為確保您的參訪順利，建議事先透過電話與道場聯繫，
          確認開放時間、共修活動安排及詳細前往路線。
        </p>
        <h3>進入道場禮儀</h3>
        <p>
          進入精舍請保持安靜莊重，著裝端莊整齊，
          手機請調為靜音模式，尊重正在共修的信眾。
        </p>
        <h3>歡迎參與共修</h3>
        <p>
          無論您是初學佛法或長年修行的信眾，宸定精舍的大門永遠為您敞開。
          歡迎與如宸法師及大眾一同共修，廣結善緣，精進菩提道上。
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3648.5!2d120.4106!3d23.9057!2m3!1f0!2f0!3f0!3m2!4i1024!5f0.7!3m2!1s0x346937f5d685d091:0xbffce951a524a4d7!2z5a-M5a6J5pys!3m2!1sen!2stw" 
        width="100%" 
        height="450" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>
  </section>

</BaseLayout>
